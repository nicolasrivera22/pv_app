# OS noise
.DS_Store
__MACOSX/

# Python caches and compiled files
__pycache__/
*.py[cod]

# Test, coverage, and tool caches
.pytest_cache/
.coverage*
htmlcov/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# Build and packaging outputs
build/
dist/
*.egg-info/

# Local runtime data generated by the app
.pv_runtime_cache/
Resultados/
Resultados_rel/

# Per-project runtime artifacts are generated locally and can be rebuilt
proyectos/*/exports/
proyectos/*/inputs/

# Local logs
*.log

# Keep tracked repo inputs and manifests
!PV_inputs.xlsx
!pv_app.spec
!proyectos/*/project.json
